#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zephyr,display = &oled;
    };

    /*
     * Physical layout -> electrical matrix (generated 1:1 from the KLE layout).
     *
     * Clean 6 rows x 7 columns per half = 42 keys each (84 total).
     *   - Left half  uses transform columns 0..6
     *   - Right half uses transform columns 7..13 (col-offset = 7, in the right .overlay)
     *
     * Row 5 (bottom) carries the finger-bottom keys + the 3 thumb keys + the
     * right-hand arrow block. The thumb keys reuse the column wires of the
     * columns whose bottom key was removed, so no 7th row is needed.
     */
    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <14>;
        rows = <6>;
        map = <
//      ╭──────────────────── LEFT (cols 0-6) ───────────────────╮ ╭──────────────────── RIGHT (cols 7-13) ───────────────────╮
        RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)    RC(0,13) RC(0,12) RC(0,11) RC(0,10) RC(0,9)  RC(0,8)  RC(0,7)
        RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)    RC(1,13) RC(1,12) RC(1,11) RC(1,10) RC(1,9)  RC(1,8)  RC(1,7)
        RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)  RC(2,6)    RC(2,13) RC(2,12) RC(2,11) RC(2,10) RC(2,9)  RC(2,8)  RC(2,7)
        RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)  RC(3,6)    RC(3,13) RC(3,12) RC(3,11) RC(3,10) RC(3,9)  RC(3,8)  RC(3,7)
        RC(4,0)  RC(4,1)  RC(4,2)  RC(4,3)  RC(4,4)  RC(4,5)  RC(4,6)    RC(4,13) RC(4,12) RC(4,11) RC(4,10) RC(4,9)  RC(4,8)  RC(4,7)
        RC(5,0)  RC(5,1)  RC(5,2)  RC(5,3)  RC(5,4)  RC(5,5)  RC(5,6)    RC(5,13) RC(5,12) RC(5,11) RC(5,10) RC(5,9)  RC(5,8)  RC(5,7)
        >;
    };

    /*
     * Shared kscan skeleton. GPIO pins are filled in per-half in
     * tvibit_left.overlay / tvibit_right.overlay (no PCB yet -> placeholders).
     * 6 row wires + 7 column wires per half.
     */
    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        wakeup-source;
        diode-direction = "col2row";
    };
};

/*
 * OLED on the nice!nano I2C header (&pro_micro_i2c). 128x32 SSD1306;
 * change width/height/multiplex-ratio for a 128x64 panel.
 * NOTE: the I2C pins (D2 = P0.17 SDA, D3 = P0.20 SCL) are reserved by this —
 * keep the matrix row/col GPIOs off those pins.
 */
&pro_micro_i2c {
    status = "okay";

    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-invdir;
        prechargep = <0x22>;
    };
};
